{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 420,
  "height": 380,
  "data": {
    "url": "data/death-rates-by-energy-source.csv",
    "format": {
      "type": "csv",
      "parse": {"deaths": "number", "ghg": "number", "share": "number"}
    }
  },
  "encoding": {
    "x": {
      "field": "deaths", "type": "quantitative",
      "scale": {"type": "log", "domain": [0.01, 40]},
      "axis": {"title": "Deaths per TWh", "grid": true, "gridColor": "#eee", "values": [0.01, 0.1, 1, 10]}
    },
    "y": {
      "field": "ghg", "type": "quantitative",
      "scale": {"type": "log", "domain": [4, 2000]},
      "axis": {"title": "Emissions (tonnes CO₂eq per GWh)", "grid": true, "gridColor": "#eee", "values": [10, 100, 1000]}
    }
  },
  "layer": [
    {
      "mark": {"type": "circle", "opacity": 0.92},
      "encoding": {
        "color": {
          "field": "Category", "type": "nominal",
          "scale": {
            "domain": ["Fossil fuel", "Renewable", "Nuclear"],
            "range": ["#5a5a5a", "#2c7fb8", "#e8336d"]
          },
          "legend": {"title": "Category", "orient": "bottom", "symbolSize": 100, "labelFontSize": 12, "titleFontSize": 12}
        },
        "size": {
          "field": "share", "type": "quantitative",
          "scale": {"range": [50, 650]},
          "legend": {"title": "Electricity share (%)", "orient": "bottom", "values": [3, 10, 22, 36], "labelFontSize": 11, "titleFontSize": 11}
        },
        "tooltip": [
          {"field": "Entity", "title": "Source"},
          {"field": "deaths", "title": "Deaths per TWh",               "format": ".2f"},
          {"field": "ghg",    "title": "GHG (tonnes CO₂eq / GWh)",    "format": ".0f"},
          {"field": "share",  "title": "Global electricity share (%)", "format": ".0f"}
        ]
      }
    },
    {
      "mark": {"type": "text", "dy": -16, "fontSize": 11.5, "fontWeight": "500", "color": "#111111", "interactive": false},
      "encoding": {
        "text": {"field": "Entity", "type": "nominal"}
      }
    }
  ]
}

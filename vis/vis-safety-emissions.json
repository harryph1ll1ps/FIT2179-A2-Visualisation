{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 720,
  "height": 480,
  "data": {
    "values": [
      {"Entity": "Coal",        "deaths": 24.6, "ghg": 970, "share": 36, "Category": "Fossil fuel"},
      {"Entity": "Oil",         "deaths": 18.4, "ghg": 720, "share": 3,  "Category": "Fossil fuel"},
      {"Entity": "Natural Gas", "deaths": 2.8,  "ghg": 440, "share": 22, "Category": "Fossil fuel"},
      {"Entity": "Biomass",     "deaths": 4.6,  "ghg": 154, "share": 2,  "Category": "Renewable"},
      {"Entity": "Hydropower",  "deaths": 1.3,  "ghg": 24,  "share": 12, "Category": "Renewable"},
      {"Entity": "Wind",        "deaths": 0.04, "ghg": 11,  "share": 7,  "Category": "Renewable"},
      {"Entity": "Nuclear",     "deaths": 0.03, "ghg": 6,   "share": 10, "Category": "Nuclear"},
      {"Entity": "Solar",       "deaths": 0.02, "ghg": 53,  "share": 4,  "Category": "Renewable"}
    ]
  },
  "encoding": {
    "x": {
      "field": "deaths", "type": "quantitative",
      "scale": {"type": "log", "domain": [0.01, 40]},
      "axis": {"title": "Deaths per TWh", "grid": true, "gridColor": "#eee", "values": [0.01, 0.1, 1, 10]}
    },
    "y": {
      "field": "ghg", "type": "quantitative",
      "scale": {"type": "log", "domain": [4, 2000]},
      "axis": {"title": "Emissions (tonnes CO₂eq per GWh)", "grid": true, "gridColor": "#eee", "values": [10, 100, 1000]}
    }
  },
  "layer": [
    {
      "mark": {"type": "circle", "opacity": 0.92},
      "encoding": {
        "color": {
          "field": "Category", "type": "nominal",
          "scale": {
            "domain": ["Fossil fuel", "Renewable", "Nuclear"],
            "range": ["#c0392b", "#27ae60", "#2471a3"]
          },
          "legend": {"title": "Category", "orient": "right", "symbolSize": 100, "labelFontSize": 12, "titleFontSize": 12}
        },
        "size": {
          "field": "share", "type": "quantitative",
          "scale": {"range": [50, 650]},
          "legend": {"title": "Electricity share (%)", "orient": "right", "values": [3, 10, 22, 36], "labelFontSize": 11, "titleFontSize": 11}
        },
        "tooltip": [
          {"field": "Entity", "title": "Source"},
          {"field": "deaths", "title": "Deaths per TWh",               "format": ".2f"},
          {"field": "ghg",    "title": "GHG (tonnes CO₂eq / GWh)",    "format": ".0f"},
          {"field": "share",  "title": "Global electricity share (%)", "format": ".0f"}
        ]
      }
    },
    {
      "mark": {"type": "text", "dy": -16, "fontSize": 11.5, "fontWeight": "500", "color": "#111111", "interactive": false},
      "encoding": {
        "text": {"field": "Entity", "type": "nominal"}
      }
    }
  ]
}

{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "width": 800,
  "height": 420,
  "padding": {"top": 10, "right": 160, "bottom": 10, "left": 10},
  "autosize": "none",

  "signals": [
    {
      "name": "projScale", "value": 153,
      "on": [{
        "events": {"type": "wheel", "consume": true},
        "update": "clamp(projScale * pow(1.001, -event.deltaY * pow(16, event.deltaMode)), 153, 10000)"
      }]
    },
    {"name": "down",  "value": null, "on": [{"events": "mousedown", "update": "xy()"}]},
    {"name": "xcur",  "value": 400,  "on": [{"events": "mousedown", "update": "tx"}]},
    {"name": "ycur",  "value": 210,  "on": [{"events": "mousedown", "update": "ty"}]},
    {
      "name": "tx", "value": 400,
      "on": [{
        "events": "[mousedown, window:mouseup] > window:mousemove",
        "update": "clamp(xcur + x() - down[0], 400 - max(0, projScale * 2.64 - 400), 400 + max(0, projScale * 2.64 - 400))"
      }]
    },
    {
      "name": "ty", "value": 210,
      "on": [{
        "events": "[mousedown, window:mouseup] > window:mousemove",
        "update": "clamp(ycur + y() - down[1], 210 - max(0, projScale * 0.88 - 210), 210 + max(0, projScale * 0.88 - 210))"
      }]
    },
    {
      "name": "nuclear_only",
      "value": false,
      "bind": {"input": "checkbox", "name": "Nuclear plants only"}
    }
  ],

  "projections": [{
    "name": "projection",
    "type": "naturalEarth1",
    "scale": {"signal": "projScale"},
    "translate": [{"signal": "tx"}, {"signal": "ty"}]
  }],

  "data": [
    {
      "name": "world",
      "url": "https://vega.github.io/vega-datasets/data/world-110m.json",
      "format": {"type": "topojson", "feature": "countries"}
    },
    {
      "name": "plants",
      "url": "data/power_plant_database_global.csv",
      "format": {"type": "csv"},
      "transform": [
        {"type": "formula", "expr": "toNumber(datum.longitude)", "as": "lon"},
        {"type": "formula", "expr": "toNumber(datum.latitude)",  "as": "lat"},
        {
          "type": "formula",
          "expr": "indexof(['Nuclear','Solar','Hydro','Wind','Gas'], datum.primary_fuel) >= 0 ? datum.primary_fuel : 'Other'",
          "as": "fuel_category"
        },
        {"type": "formula", "expr": "datum.fuel_category === 'Nuclear' ? 1 : 0", "as": "nuclear_order"},
        {"type": "filter",  "expr": "!nuclear_only || datum.fuel_category === 'Nuclear'"},
        {"type": "geopoint", "projection": "projection", "fields": ["lon", "lat"], "as": ["px", "py"]},
        {"type": "filter",  "expr": "datum.px != null && datum.py != null"}
      ]
    }
  ],

  "scales": [{
    "name": "color",
    "type": "ordinal",
    "domain": ["Nuclear", "Solar", "Hydro", "Wind", "Gas", "Other"],
    "range":  ["#E84393", "#E69F00", "#56B4E9", "#009E73", "#8B5E3C", "#666666"]
  }],

  "legends": [{
    "fill": "color",
    "title": "Primary Fuel",
    "orient": "right",
    "symbolType": "circle",
    "symbolOpacity": 0.65
  }],

  "marks": [
    {
      "type": "shape",
      "from": {"data": "world"},
      "encode": {
        "update": {
          "fill":        {"value": "#e8e8e8"},
          "stroke":      {"value": "#ffffff"},
          "strokeWidth": {"value": 0.5}
        }
      },
      "transform": [{"type": "geoshape", "projection": "projection"}]
    },
    {
      "type": "symbol",
      "from": {"data": "plants"},
      "sort": {"field": "nuclear_order", "order": "ascending"},
      "encode": {
        "update": {
          "x":       {"field": "px"},
          "y":       {"field": "py"},
          "size":    {"value": 8},
          "opacity": {"value": 0.65},
          "fill":    {"scale": "color", "field": "fuel_category"},
          "tooltip": {
            "signal": "{'Plant': datum.name, 'Country': datum.country_long, 'Fuel': datum.fuel_category}"
          }
        }
      }
    }
  ]
}

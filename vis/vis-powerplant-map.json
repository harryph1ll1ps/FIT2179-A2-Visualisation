{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 840,
  "height": 470,
  "background": null,
  "title": {
    "text": "Every power plant on Earth, by energy type",
    "subtitle": "Each dot is a generating station. Use the region menu to zoom in; click a group in the legend to isolate it.",
    "anchor": "start",
    "fontSize": 17,
    "subtitleFontSize": 12,
    "subtitleColor": "#52606d",
    "color": "#102a43",
    "offset": 12
  },
  "params": [
    {
      "name": "region",
      "value": "World",
      "bind": {
        "input": "select",
        "name": "Zoom to region:  ",
        "options": ["World", "Oceania", "Asia", "Europe", "Africa", "North America", "South America"]
      }
    },
    {
      "name": "regScale",
      "expr": "region === 'Oceania' ? 430 : region === 'Asia' ? 300 : region === 'Europe' ? 620 : region === 'Africa' ? 320 : region === 'North America' ? 300 : region === 'South America' ? 360 : 152"
    },
    {
      "name": "regCx",
      "expr": "region === 'Oceania' ? 150 : region === 'Asia' ? 95 : region === 'Europe' ? 12 : region === 'Africa' ? 18 : region === 'North America' ? -100 : region === 'South America' ? -62 : 0"
    },
    {
      "name": "regCy",
      "expr": "region === 'Oceania' ? -25 : region === 'Asia' ? 35 : region === 'Europe' ? 51 : region === 'Africa' ? 2 : region === 'North America' ? 48 : region === 'South America' ? -22 : 0"
    },
    {
      "name": "showType",
      "value": "All",
      "bind": {
        "input": "radio",
        "name": "Show:  ",
        "options": ["All", "Fossil fuels", "Renewables", "Nuclear"]
      }
    }
  ],
  "projection": {
    "type": "naturalEarth1",
    "scale": {"expr": "regScale"},
    "center": {"expr": "[regCx, regCy]"}
  },
  "layer": [
    {
      "data": {"sphere": true},
      "mark": {"type": "geoshape", "fill": "#fbfcfd", "stroke": "#d0d7de", "strokeWidth": 0.8}
    },
    {
      "data": {"graticule": {"step": [20, 20]}},
      "mark": {"type": "geoshape", "stroke": "#e6eaef", "strokeWidth": 0.35}
    },
    {
      "data": {
        "url": "https://vega.github.io/vega-datasets/data/world-110m.json",
        "format": {"type": "topojson", "feature": "countries"}
      },
      "mark": {"type": "geoshape", "fill": "#e2e7ee", "stroke": "#ffffff", "strokeWidth": 0.5}
    },
    {
      "data": {
        "url": "data/global-power-plant-database.csv",
        "format": {
          "type": "csv",
          "parse": {"latitude": "number", "longitude": "number", "capacity_mw": "number"}
        }
      },
      "transform": [
        {
          "calculate": "indexof(['Coal','Gas','Oil','Petcoke','Cogeneration'], datum.primary_fuel) >= 0 ? 'Fossil fuels' : (datum.primary_fuel === 'Nuclear' ? 'Nuclear' : (indexof(['Solar','Hydro','Wind','Geothermal','Biomass','Waste','Wave and Tidal'], datum.primary_fuel) >= 0 ? 'Renewables' : 'Unclassified'))",
          "as": "fuel_group"
        },
        {"filter": "datum.fuel_group !== 'Unclassified'"},
        {"filter": "showType === 'All' || datum.fuel_group === showType"},
        {
          "calculate": "datum.fuel_group === 'Nuclear' ? 1 : 0",
          "as": "draw_order"
        }
      ],
      "params": [
        {
          "name": "fuelSelect",
          "select": {"type": "point", "fields": ["fuel_group"]},
          "bind": "legend"
        }
      ],
      "mark": {"type": "circle", "size": 16, "stroke": "#ffffff", "strokeWidth": 0.15},
      "encoding": {
        "longitude": {"field": "longitude", "type": "quantitative"},
        "latitude": {"field": "latitude", "type": "quantitative"},
        "order": {"field": "draw_order", "type": "quantitative"},
        "color": {
          "field": "fuel_group",
          "type": "nominal",
          "title": "Energy type",
          "scale": {
            "domain": ["Fossil fuels", "Renewables", "Nuclear"],
            "range": ["#5a5a5a", "#2c7fb8", "#e8336d"]
          },
          "legend": {
            "orient": "right",
            "symbolType": "circle",
            "symbolSize": 110,
            "titleFontSize": 12,
            "labelFontSize": 12,
            "titlePadding": 8
          }
        },
        "opacity": {
          "condition": {"param": "fuelSelect", "value": 0.78},
          "value": 0.06
        },
        "tooltip": [
          {"field": "name", "type": "nominal", "title": "Plant"},
          {"field": "country_long", "type": "nominal", "title": "Country"},
          {"field": "fuel_group", "type": "nominal", "title": "Energy type"},
          {"field": "primary_fuel", "type": "nominal", "title": "Fuel"},
          {"field": "capacity_mw", "type": "quantitative", "title": "Capacity (MW)", "format": ","}
        ]
      }
    }
  ],
  "config": {
    "view": {"stroke": null},
    "font": "Segoe UI, Tahoma, sans-serif"
  }
}

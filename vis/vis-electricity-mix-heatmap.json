{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": { "step": 120 },
  "height": { "step": 45 },
  "data": { "url": "data/electricity-mix-pct.csv" },
  "transform": [
    { "filter": "datum.Entity !== 'World'" },
    {
      "fold": ["Fossil fuels", "Nuclear", "Renewables"],
      "as": ["Source", "Percentage"]
    },
    { "calculate": "format(datum.Percentage, '.0f') + '%'", "as": "PctLabel" }
  ],
  "encoding": {
    "y": {
      "field": "Entity",
      "type": "nominal",
      "title": null,
      "sort": { "field": "Percentage", "op": "sum", "order": "descending" },
      "axis": { "labelFontSize": 13 }
    },
    "x": {
      "field": "Source",
      "type": "nominal",
      "title": null,
      "sort": ["Fossil fuels", "Nuclear", "Renewables"],
      "axis": { "labelFontSize": 13, "labelAngle": 0 }
    }
  },
  "layer": [
    {
      "mark": { "type": "rect", "stroke": "#fff", "strokeWidth": 2 },
      "encoding": {
        "color": {
          "field": "Percentage",
          "type": "quantitative",
          "scale": { "scheme": "blues", "domain": [0, 100] },
          "legend": { "title": "Share of electricity (%)", "titleFontSize": 11 }
        },
        "tooltip": [
          { "field": "Entity", "type": "nominal", "title": "Country" },
          { "field": "Source", "type": "nominal", "title": "Source" },
          { "field": "Percentage", "type": "quantitative", "title": "Share (%)", "format": ".1f" }
        ]
      }
    },
    {
      "mark": { "type": "text", "fontSize": 13, "fontWeight": "bold", "color": "#000000" },
      "encoding": {
        "text": { "field": "PctLabel", "type": "nominal" }
      }
    }
  ]
}

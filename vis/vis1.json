{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "The Rise of Global Unicorn Companies",
  "width": 700,
  "height": 450,
  "data": {
    "url": "../data/Unicorn_Companies.csv"
  },
  "transform": [
    {
      "calculate": "toNumber(datum['Year Founded'])",
      "as": "FoundedYear"
    },
    {
      "calculate": "replace(replace(datum.Valuation, '$', ''), 'B', '')",
      "as": "ValuationText"
    },
    {
      "calculate": "toNumber(datum.ValuationText)",
      "as": "ValuationBillions"
    },
    {
      "calculate": "replace(datum.Funding, '$', '')",
      "as": "FundingText"
    },
    {
      "calculate": "replace(replace(datum.FundingText, 'B', ''), 'M', '')",
      "as": "FundingNumberText"
    },
    {
      "calculate": "indexof(datum.Funding, 'B') > -1 ? toNumber(datum.FundingNumberText) * 1000 : indexof(datum.Funding, 'M') > -1 ? toNumber(datum.FundingNumberText) : null",
      "as": "FundingMillions"
    },
    {
      "filter": "isValid(datum.FoundedYear) && isValid(datum.ValuationBillions) && isValid(datum.FundingMillions)"
    }
  ],
  "mark": {
    "type": "circle",
    "filled": true,
    "opacity": 0.75,
    "stroke": "white",
    "strokeWidth": 0.5
  },
  "encoding": {
    "x": {
      "field": "FoundedYear",
      "type": "quantitative",
      "title": "Year Founded",
      "scale": {
        "zero": false
      },
      "axis": {
        "tickMinStep": 1
      }
    },
    "y": {
      "field": "ValuationBillions",
      "type": "quantitative",
      "title": "Valuation (Billions USD)"
    },
    "size": {
      "field": "FundingMillions",
      "type": "quantitative",
      "title": "Funding (Millions USD)",
      "scale": {
        "range": [40, 1200]
      }
    },
    "color": {
      "field": "Industry",
      "type": "nominal"
    },

    "tooltip": [
      {"field": "Company"},
      {"field": "Country"},
      {"field": "Industry"},
      {"field": "FoundedYear", "title": "Year Founded"},
      {"field": "Valuation"},
      {"field": "Funding"}
    ]
  }
}

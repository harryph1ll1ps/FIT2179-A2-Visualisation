{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 800,
  "height": 520,
  "data": {
    "values": [
      {"Entity": "Brown coal", "deaths": 32.72, "category": "Fossil", "xpos": 140, "ypos": 390},
      {"Entity": "Coal",       "deaths": 24.62, "category": "Fossil", "xpos": 395, "ypos": 390},
      {"Entity": "Oil",        "deaths": 18.43, "category": "Fossil", "xpos": 620, "ypos": 390},
      {"Entity": "Gas",        "deaths": 2.821, "category": "Fossil", "xpos": 60,  "ypos": 115},
      {"Entity": "Biomass",    "deaths": 4.63,  "category": "Renewable", "xpos": 200, "ypos": 115},
      {"Entity": "Hydropower", "deaths": 1.3,   "category": "Renewable", "xpos": 335, "ypos": 115},
      {"Entity": "Nuclear",    "deaths": 0.03,  "category": "Nuclear",   "xpos": 435, "ypos": 115},
      {"Entity": "Wind",       "deaths": 0.035, "category": "Renewable", "xpos": 505, "ypos": 115},
      {"Entity": "Solar",      "deaths": 0.019, "category": "Renewable", "xpos": 575, "ypos": 115}
    ]
  },
  "transform": [
    {
      "calculate": "datum.deaths >= 1 ? format(datum.deaths, '.2f') : format(datum.deaths, '.3f')",
      "as": "deaths_label"
    }
  ],
  "layer": [
    {
      "mark": {"type": "circle", "opacity": 0.85},
      "encoding": {
        "x": {
          "field": "xpos",
          "type": "quantitative",
          "scale": {"domain": [0, 800], "nice": false},
          "axis": null
        },
        "y": {
          "field": "ypos",
          "type": "quantitative",
          "scale": {"domain": [0, 520], "nice": false},
          "axis": null
        },
        "size": {
          "field": "deaths",
          "type": "quantitative",
          "scale": {
            "type": "linear",
            "domain": [0.019, 32.72],
            "range": [60, 50000]
          },
          "legend": null
        },
        "color": {
          "field": "category",
          "type": "nominal",
          "scale": {
            "domain": ["Fossil", "Renewable", "Nuclear"],
            "range": ["#c0392b", "#3aab6d", "#2980b9"]
          },
          "legend": {
            "title": null,
            "orient": "bottom",
            "labelFontSize": 12,
            "symbolSize": 200
          }
        },
        "tooltip": [
          {"field": "Entity",   "type": "nominal",      "title": "Source"},
          {"field": "deaths",   "type": "quantitative", "title": "Deaths per TWh", "format": ".3f"},
          {"field": "category", "type": "nominal",      "title": "Category"}
        ]
      }
    },
    {
      "mark": {"type": "text", "fontWeight": "bold", "fontSize": 13},
      "encoding": {
        "x": {"field": "xpos", "type": "quantitative"},
        "y": {"field": "ypos", "type": "quantitative"},
        "text": {"field": "Entity"},
        "color": {
          "condition": {"test": "datum.deaths > 1", "value": "white"},
          "value": "#333"
        },
        "dy": {
          "condition": {"test": "datum.deaths > 1", "value": -10},
          "value": 18
        }
      }
    },
    {
      "mark": {"type": "text", "fontSize": 12},
      "encoding": {
        "x": {"field": "xpos", "type": "quantitative"},
        "y": {"field": "ypos", "type": "quantitative"},
        "text": {"field": "deaths_label"},
        "color": {
          "condition": {"test": "datum.deaths > 1", "value": "white"},
          "value": "#555"
        },
        "dy": {
          "condition": {"test": "datum.deaths > 1", "value": 10},
          "value": 32
        }
      }
    }
  ]
}
